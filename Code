                <FieldOverlay
                  key={idx}
                  field={field}
                  isActive={activeFieldIdx === globalIdx}
                  onClick={() => {
                    if (!field.value) {
                      setActiveFieldIdx(globalIdx);
                      applyToField(globalIdx);
                    }
                  }}
                />
              );
            })}
          </PdfViewer>
        </div>
      </div>
    </div>
  );
}

