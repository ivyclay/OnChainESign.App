model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          String    @default("user") // user, admin
  plan          String    @default("free") // free, pro, enterprise
  documentsUsed Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  documents     Document[]
  subscriptions Subscription[]
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            String    // pro, enterprise
  status          String    @default("active") // active, cancelled, expired
  paypalSubId     String?   @unique
  paypalOrderId   String?
  amount          Float
  currency        String    @default("USD")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

model Document {
  id              String          @id @default(cuid())
  fileName        String
  fileType        String
  fileSize        Int
  cloudPath       String
  documentHash    String
  status          String          @default("draft") // draft, pending, partially_signed, signed, completed
  agentName       String
  agentEmail      String
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  blockchainTxHash String?
  blockchainNetwork String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  signatures      Signature[]
  auditLogs       AuditLog[]
  fields          DocumentField[]
  parties         TransactionParty[]
}

model TransactionParty {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  name        String
  email       String
  role        String   // freeform role e.g. Buyer, Seller, Attorney, Tenant, etc.
  company     String?
  phone       String?
  orderIndex  Int      @default(0)
  signingToken String?  @unique  // unique token for per-party signing link
  signedAt    DateTime?          // when this party completed signing
  status      String   @default("pending") // pending, sent, viewed, signed
  createdAt   DateTime @default(now())

  @@index([documentId])
  @@index([signingToken])
}

model DocumentField {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fieldType   String   // signature, date, initials, text
  pageNumber  Int
  xPercent    Float    // x position as percentage of page width
  yPercent    Float    // y position as percentage of page height
  widthPercent  Float  // width as percentage
  heightPercent Float  // height as percentage
  label       String?
  required    Boolean  @default(true)
  value       String?  @db.Text
  signedAt    DateTime?
  assignedPartyId String? // which party this field is assigned to
  createdAt   DateTime @default(now())
}

model Signature {
  id              String    @id @default(cuid())
  documentId      String
  document        Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signerName      String
  signerEmail     String
  signerRole      String
  signatureType   String
  signatureData   String    @db.Text
  signedAt        DateTime  @default(now())
  ipAddress       String
  userAgent       String    @db.Text
  deviceInfo      String    @db.Text
  timezone        String
  consentGiven    Boolean   @default(true)
  intentConfirmed Boolean   @default(true)
  signatureHash   String
  certificatePath String?
  partyId         String?   // link to the TransactionParty
  createdAt       DateTime  @default(now())
  auditLogs       AuditLog[]
}

model AuditLog {
  id          String     @id @default(cuid())
  documentId  String
  document    Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatureId String?
  signature   Signature? @relation(fields: [signatureId], references: [id], onDelete: SetNull)
  action      String
  actor       String
  actorEmail  String?
  ipAddress   String?
  userAgent   String?    @db.Text
  details     String?    @db.Text
  timestamp   DateTime   @default(now())
}
