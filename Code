    }
    fetch('/api/paypal/client-id')
      .then(r => r.json())
      .then(data => {
        setClientId(data.clientId || '');
        setLoading(false);
      })
      .catch(() => setLoading(false));
  }, [status, router, planType]);

  if (status === 'loading' || loading) {
